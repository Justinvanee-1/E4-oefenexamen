<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="E4_Project.Pages.InventoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:E4_Project.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#F2F2F2">

        <StackPanel Padding="25" Spacing="15">

            <!-- Titel -->
            <TextBlock Text="Inventory"
                   FontSize="28"
                   FontWeight="Bold"
                   Foreground="Gray"/>

            <!-- Navigatie -->
            <StackPanel Orientation="Horizontal" Spacing="10">

                <Button Content="← Home"
                        Background="#E0E0E0"
                    Click="Home_Click"/>

                <Button Content="＋ Add Item"
                        Background="#E0E0E0"
                    Click="AddItem_Click"/>

            </StackPanel>

            <!-- Zoekbalk -->
            <TextBox x:Name="SearchBox"
                     Background="#E0E0E0"
                 PlaceholderText="Search by item name or magical addon..."
                 TextChanged="SearchBox_TextChanged"
                 Width="350"/>

            <!-- Inventory lijst -->
            <ListView x:Name="InventoryList">

                <ListView.ItemTemplate>
                    <DataTemplate>

                        <!-- Item kaart -->
                        <Border Background="White"
                            BorderBrush="LightGray"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12"
                            Margin="0,5">

                            <Grid ColumnDefinitions="*,Auto,Auto,Auto">>

                                <StackPanel>
                                    <TextBlock Text="{Binding ItemName}"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="Black"/>

                                    <TextBlock Text="{Binding Type}"
                                           Foreground="Black"/>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Background="#E0E0E0"
                                    Content="Details"
                                    Tag="{Binding ItemId}"
                                    Click="Details_Click"
                                    Margin="10,0"/>

                                <Button Grid.Column="2"
                                        Background="#E0E0E0"
                                    Content="Delete"
                                    Tag="{Binding ItemId}"
                                    Click="Delete_Click"/>

                            </Grid>

                        </Border>

                    </DataTemplate>
                </ListView.ItemTemplate>

            </ListView>

        </StackPanel>

    </Grid>
</Page>
