<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="E4_Project.Pages.AddItemPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:E4_Project.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <ScrollViewer>
            <StackPanel Padding="20" Spacing="10">

                <TextBox x:Name="ItemNameBox"
                     Header="Item Name"
                     PlaceholderText="Enter the name of the item"/>

                <TextBox x:Name="DescriptionBox"
                     Header="Description"
                     PlaceholderText="Describe the item"/>

                <TextBox x:Name="TypeBox"
                     Header="Type"
                     PlaceholderText="Enter the type (Sword, Shield, Armor...)"/>

                <ComboBox x:Name="RarityBox"
                      Header="Rarity"
                      PlaceholderText="Select item rarity">

                    <ComboBoxItem Content="Common"/>
                    <ComboBoxItem Content="Uncommon"/>
                    <ComboBoxItem Content="Rare"/>
                    <ComboBoxItem Content="Epic"/>
                    <ComboBoxItem Content="Legendary"/>

                </ComboBox>

                <TextBox x:Name="PowerBox"
                     Header="Power"
                     PlaceholderText="Enter power value"/>

                <TextBox x:Name="SpeedBox"
                     Header="Speed"
                     PlaceholderText="Enter speed value"/>

                <TextBox x:Name="DurabilityBox"
                     Header="Durability"
                     PlaceholderText="Enter durability value"/>

                <TextBox x:Name="MagicalAddonsBox"
                     Header="Magical Addons"
                     PlaceholderText="Enter magical effects (optional)"/>

                <Button Content="Save Item"
                    Click="Save_Click"
                    HorizontalAlignment="Left"/>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
